# All server config. No secrets are required — this server has nothing to
# authenticate to; it only reads local Markdown files read-only.

# Render sets PORT automatically. Default 3001 if unset (e.g. local dev).
PORT=3001

# Bind address. Render expects 0.0.0.0. Use 127.0.0.1 for local-only dev if
# you want DNS-rebinding protection enabled automatically (see
# docs/architecture.md).
HOST=0.0.0.0

# Where this server reads SKILL.md files from. Defaults to
# ../../agent-skill-kit/skills (resolved relative to this package's cwd) if
# unset — do not point this at a path outside the repository.
# SKILL_KIT_PATH=../../agent-skill-kit/skills

# The public URL of the Vercel web app that will call this server. Used to
# restrict the Host header this server accepts (DNS-rebinding mitigation).
# Leave unset only for local development.
ALLOWED_ORIGIN=https://your-vercel-app.vercel.app

# Per-IP requests/minute on POST /mcp. Default 60 if unset.
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Cosmetic server name reported in MCP initialize and GET /health.
MCP_SERVER_NAME=ai-product-factory-skill-server

# "info" (default) or "silent". Tool-call logs never include raw request
# bodies or business idea text — see src/logging.ts.
MCP_LOG_LEVEL=info
