# Server-side only. Never reference these with a NEXT_PUBLIC_ prefix.

# Demo mode gate for /api/blueprint. Default true if unset; any value other
# than the literal string "false" is treated as true.
DEMO_MODE=true

# Where the local Skill Tool Layer reads SKILL.md files from. Defaults to
# ../../agent-skill-kit/skills (resolved relative to this app's cwd) if unset.
# SKILL_KIT_PATH=../../agent-skill-kit/skills

# Optional: base URL (including the /mcp path) of the deployed public MCP
# Skill Server. Server-side only — never exposed to the client. When set,
# the spec stage tries recommend_skills on this server first; on any
# failure (network error, timeout, rate limit, invalid response) it falls
# back to the local @ai-product-factory/skill-tools package automatically.
# Leave unset to always use the local package (the original Phase 4A/4B
# behavior).
# MCP_SERVER_URL=https://ai-product-factory-mcp.onrender.com/mcp

# Per-request timeout (ms) for the MCP_SERVER_URL call above. Keep this
# short (recommended 3000-5000) so a slow MCP server never makes the demo
# feel broken. Default 4000 if unset.
# MCP_TIMEOUT_MS=4000

# --- Live Gemini Mode (apps/web/src/server/llm/) -----------------------
# Demo Mode is always available and remains the default with ALL of the
# following unset. Live Gemini Mode only runs when ALL three of
# ENABLE_LIVE_AI, LLM_PROVIDER=gemini, and LLM_API_KEY are set — a client
# requesting generationMode: "live" cannot bypass this server-side gate.

# Server-side kill switch for Live Gemini Mode. Default false (disabled) if unset.
# ENABLE_LIVE_AI=true

# Only "gemini" is implemented today (see src/server/llm/gemini-provider.ts).
# LLM_PROVIDER=gemini

# Server-side only — never sent to the client, never logged, never included
# in any error message. Required for Live Gemini Mode to run at all.
# LLM_API_KEY=your-gemini-api-key

# Gemini model id. Default gemini-2.5-flash if unset. Free-tier quota for any
# given model varies by Google Cloud project — if generation fails with a
# 429 "quota exceeded" provider_error, check which models your key actually
# has free quota for and set this accordingly. Model names/availability can
# also change upstream — verify against current Gemini API docs.
# LLM_MODEL=gemini-2.5-flash

# Per-request timeout (ms) for the Gemini call. Generation takes longer than
# a typical API call, so this is more generous than MCP_TIMEOUT_MS. Default
# 30000 if unset (matches the "up to 30 seconds" copy shown in the UI loader).
# LLM_TIMEOUT_MS=30000

# Per-anonymous-user, per-UTC-day cap on Live Gemini requests. Default 10 if
# unset. Enforced by an in-memory counter keyed by an opaque cookie
# (src/server/anon-id.ts) — see docs/architecture.md, "Live Gemini Mode" for
# the documented limitations (resets on cold start, no cross-instance
# sharing on serverless, bypassable by clearing cookies).
# LIVE_AI_DAILY_LIMIT=10
